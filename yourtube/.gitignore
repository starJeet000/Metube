# Dependencies
# Using 'node_modules/' instead of '/node_modules' ensures it is ignored 
# in both your 'yourtube' and 'server' subdirectories.
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js Build Output
.next/
out/

# Production/Backend Build Folders
build/
dist/

# 🌟 CRITICAL: Local Video Uploads
# This prevents your test videos in the server from being pushed to GitHub.
server/uploads/
uploads/

# Debug Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment Variables
# Keep your secrets private!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Operating System Files
.DS_Store
Thumbs.db
*.pem

# Vercel & Deployment
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts